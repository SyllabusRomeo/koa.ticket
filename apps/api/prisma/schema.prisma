generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  username           String?   @unique
  passwordHash       String    @map("password_hash")
  firstName          String    @map("first_name")
  lastName           String    @map("last_name")
  isActive           Boolean   @default(true) @map("is_active")
  mustChangePassword Boolean   @default(false) @map("must_change_password")
  failedLoginCount   Int       @default(0) @map("failed_login_count")
  lockedUntil        DateTime? @map("locked_until")
  passwordChangedAt  DateTime? @map("password_changed_at")
  lastLoginAt        DateTime? @map("last_login_at")
  mfaEnabled         Boolean   @default(false) @map("mfa_enabled")
  mfaSecret          String?   @map("mfa_secret")
  /** local | entra */
  authProvider       String    @default("local") @map("auth_provider")
  /** IdP subject (e.g. Entra oid) when linked via SSO */
  externalSubject    String?   @map("external_subject")
  departmentId       String?   @map("department_id")
  locationId         String?   @map("location_id")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  department Department? @relation(fields: [departmentId], references: [id])
  location   Location?   @relation(fields: [locationId], references: [id])
  roles      UserRole[]
  /** Additive grants beyond the primary role (role ∪ extras = effective permissions). */
  extraPermissions UserPermission[]
  sessions   Session[]
  teamMembers TeamMember[]
  passwordResetTokens PasswordResetToken[]
  authChallenges AuthChallenge[]
  requestedTickets Ticket[] @relation("TicketRequester")
  assignedTickets  Ticket[] @relation("TicketAssignee")
  ticketComments   TicketComment[]
  ticketHistory    TicketHistory[]
  attachments      TicketAttachment[]
  knowledgeAttachments KnowledgeAttachment[]
  auditLogs        AuditLog[]
  notifications    Notification[]
  notificationPreferences NotificationPreference[]
  knowledgeArticles KnowledgeArticle[]
  assignedAssets   Asset[] @relation("AssetAssignee")
  approvals        Approval[] @relation("ApprovalApprover")
  ticketWatchers   TicketWatcher[]
  ticketWorkLogs   TicketWorkLog[]
  skills           UserSkill[]

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  roles RolePermission[]
  users UserPermission[]

  @@map("permissions")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

/** Per-user permission overrides — additive only (never removes role grants). */
model UserPermission {
  userId       String   @map("user_id")
  permissionId String   @map("permission_id")
  assignedAt   DateTime @default(now()) @map("assigned_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

model RolePermission {
  roleId       String @map("role_id")
  permissionId String @map("permission_id")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Session {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash")
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  ipAddress String?   @map("ip_address")
  userAgent String?   @map("user_agent")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  ipAddress String?  @map("ip_address")
  success   Boolean
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, createdAt])
  @@map("login_attempts")
}

/** Short-lived MFA login / OAuth CSRF challenges */
model AuthChallenge {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash")
  /// mfa_login | entra_oauth
  kind      String
  userId    String?   @map("user_id")
  /// Optional JSON blob (e.g. OAuth nonce meta)
  meta      String?
  expiresAt DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([kind, expiresAt])
  @@map("auth_challenges")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// Phase 2 — Organization (schema now; APIs in Phase 2)

model Location {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  country   String?
  site      String?
  timezone  String    @default("Africa/Accra")
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  users       User[]
  departments Department[]
  teams       Team[]
  tickets     Ticket[]
  assets      Asset[]

  @@map("locations")
}

model Department {
  id         String    @id @default(cuid())
  code       String    @unique
  name       String
  locationId String?   @map("location_id")
  isActive   Boolean   @default(true) @map("is_active")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  location Location? @relation(fields: [locationId], references: [id])
  users    User[]
  teams    Team[]
  tickets  Ticket[]

  @@map("departments")
}

model Team {
  id           String    @id @default(cuid())
  code         String    @unique
  name         String
  description  String?
  locationId   String?   @map("location_id")
  departmentId String?   @map("department_id")
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  location   Location?    @relation(fields: [locationId], references: [id])
  department Department?  @relation(fields: [departmentId], references: [id])
  members    TeamMember[]
  tickets    Ticket[]

  @@map("teams")
}

model TeamMember {
  teamId   String   @map("team_id")
  userId   String   @map("user_id")
  isLead   Boolean  @default(false) @map("is_lead")
  joinedAt DateTime @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@map("team_members")
}

// Phase 3 — Core ticketing

model TicketType {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  prefix      String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tickets Ticket[]

  @@map("ticket_types")
}

model TicketStatus {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  isTerminal Boolean @default(false) @map("is_terminal")
  pausesSla Boolean  @default(false) @map("pauses_sla")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tickets Ticket[]
  fromTransitions TicketStatusTransition[] @relation("FromStatus")
  toTransitions   TicketStatusTransition[] @relation("ToStatus")

  @@map("ticket_statuses")
}

model TicketStatusTransition {
  id           String @id @default(cuid())
  fromStatusId String @map("from_status_id")
  toStatusId   String @map("to_status_id")

  fromStatus TicketStatus @relation("FromStatus", fields: [fromStatusId], references: [id], onDelete: Cascade)
  toStatus   TicketStatus @relation("ToStatus", fields: [toStatusId], references: [id], onDelete: Cascade)

  @@unique([fromStatusId, toStatusId])
  @@map("ticket_status_transitions")
}

model Category {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  isActive  Boolean   @default(true) @map("is_active")
  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  subcategories Subcategory[]
  tickets       Ticket[]

  @@map("categories")
}

model Subcategory {
  id         String    @id @default(cuid())
  code       String
  name       String
  categoryId String    @map("category_id")
  isActive   Boolean   @default(true) @map("is_active")
  deletedAt  DateTime? @map("deleted_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tickets  Ticket[]

  @@unique([categoryId, code])
  @@map("subcategories")
}

model Priority {
  id        String @id @default(cuid())
  code      String @unique
  name      String
  rank      Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tickets Ticket[]
  matrix  PriorityMatrix[]

  @@map("priorities")
}

model PriorityMatrix {
  id         String @id @default(cuid())
  impact     String
  urgency    String
  priorityId String @map("priority_id")

  priority Priority @relation(fields: [priorityId], references: [id])

  @@unique([impact, urgency])
  @@map("priority_matrix")
}

model TicketNumberSequence {
  id     String @id @default(cuid())
  prefix String
  year   Int
  lastValue Int @default(0) @map("last_value")

  @@unique([prefix, year])
  @@map("ticket_number_sequences")
}

model Ticket {
  id              String    @id @default(cuid())
  number          String    @unique
  title           String
  description     String
  typeId          String    @map("type_id")
  statusId        String    @map("status_id")
  priorityId      String?   @map("priority_id")
  categoryId      String?   @map("category_id")
  subcategoryId   String?   @map("subcategory_id")
  impact          String?
  urgency         String?
  priorityOverride Boolean  @default(false) @map("priority_override")
  requesterId     String    @map("requester_id")
  assigneeId      String?   @map("assignee_id")
  teamId          String?   @map("team_id")
  departmentId    String?   @map("department_id")
  locationId      String?   @map("location_id")
  parentId        String?   @map("parent_id")
  /** When set, this ticket was merged into another (duplicate closed as merged). */
  mergedIntoId    String?   @map("merged_into_id")
  /** Major incident flag for P1 / business-critical outages. */
  majorIncident   Boolean   @default(false) @map("major_incident")
  /** Problem management — root cause analysis. */
  rootCause       String?   @map("root_cause")
  /** Problem management — temporary workaround for known errors. */
  workaround      String?
  /** Change management — risk summary (low/medium/high or free text). */
  changeRisk      String?   @map("change_risk")
  /** Change implementation plan. */
  changePlan      String?   @map("change_plan")
  /** Rollback / backout plan. */
  rollbackPlan    String?   @map("rollback_plan")
  scheduledStart  DateTime? @map("scheduled_start")
  scheduledEnd    DateTime? @map("scheduled_end")
  /** When true, change should go through CAB / approvers before implement. */
  cabRequired     Boolean   @default(false) @map("cab_required")
  /** Catalog item this ticket was requested from (optional). */
  catalogItemId   String?   @map("catalog_item_id")
  /** Validated answers from the catalog item form schema (JSON). */
  catalogAnswers  Json?     @map("catalog_answers")
  version         Int       @default(1)
  firstResponseAt DateTime? @map("first_response_at")
  resolvedAt      DateTime? @map("resolved_at")
  closedAt        DateTime? @map("closed_at")
  dueAt           DateTime? @map("due_at")
  deletedAt       DateTime? @map("deleted_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  type        TicketType     @relation(fields: [typeId], references: [id])
  status      TicketStatus   @relation(fields: [statusId], references: [id])
  priority    Priority?      @relation(fields: [priorityId], references: [id])
  category    Category?      @relation(fields: [categoryId], references: [id])
  subcategory Subcategory?   @relation(fields: [subcategoryId], references: [id])
  requester   User           @relation("TicketRequester", fields: [requesterId], references: [id])
  assignee    User?          @relation("TicketAssignee", fields: [assigneeId], references: [id])
  team        Team?          @relation(fields: [teamId], references: [id])
  department  Department?    @relation(fields: [departmentId], references: [id])
  location    Location?      @relation(fields: [locationId], references: [id])
  parent      Ticket?        @relation("TicketHierarchy", fields: [parentId], references: [id])
  children    Ticket[]       @relation("TicketHierarchy")
  mergedInto  Ticket?        @relation("TicketMerge", fields: [mergedIntoId], references: [id])
  mergedFrom  Ticket[]       @relation("TicketMerge")
  comments    TicketComment[]
  history     TicketHistory[]
  attachments TicketAttachment[]
  slaInstances SlaInstance[]
  assets      TicketAsset[]
  approvals   Approval[]
  watchers    TicketWatcher[]
  workLogs    TicketWorkLog[]
  emailMessages EmailMessage[]

  @@index([requesterId])
  @@index([assigneeId])
  @@index([statusId])
  @@index([teamId])
  @@index([parentId])
  @@index([mergedIntoId])
  @@index([majorIncident])
  @@index([catalogItemId])
  @@index([createdAt])
  @@map("tickets")
}

model TicketWatcher {
  id        String   @id @default(cuid())
  ticketId  String   @map("ticket_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ticketId, userId])
  @@index([userId])
  @@map("ticket_watchers")
}

model TicketWorkLog {
  id        String   @id @default(cuid())
  ticketId  String   @map("ticket_id")
  authorId  String   @map("author_id")
  minutes   Int
  note      String?
  workedAt  DateTime @default(now()) @map("worked_at")
  createdAt DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@index([ticketId])
  @@index([authorId])
  @@map("ticket_work_logs")
}

model TicketComment {
  id        String   @id @default(cuid())
  ticketId  String   @map("ticket_id")
  authorId  String   @map("author_id")
  body      String
  isInternal Boolean @default(false) @map("is_internal")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])
  emailMessages EmailMessage[]

  @@index([ticketId])
  @@map("ticket_comments")
}

/** Inbound/outbound email Message-ID index for threading + dedupe */
model EmailMessage {
  id          String   @id @default(cuid())
  /// Normalized Message-ID (angle brackets stripped, lowercased)
  messageId   String   @unique @map("message_id")
  inReplyTo   String?  @map("in_reply_to")
  /// Space-separated normalized Message-IDs from References header
  references  String?
  direction   String
  ticketId    String   @map("ticket_id")
  commentId   String?  @map("comment_id")
  subject     String?
  fromAddress String?  @map("from_address")
  toAddress   String?  @map("to_address")
  createdAt   DateTime @default(now()) @map("created_at")

  ticket  Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  comment TicketComment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([inReplyTo])
  @@map("email_messages")
}

model TicketHistory {
  id         String   @id @default(cuid())
  ticketId   String   @map("ticket_id")
  actorId    String?  @map("actor_id")
  field      String
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  createdAt  DateTime @default(now()) @map("created_at")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorId], references: [id])

  @@index([ticketId])
  @@map("ticket_history")
}

// Phase 4 — Attachments & audit

model TicketAttachment {
  id           String   @id @default(cuid())
  ticketId     String   @map("ticket_id")
  uploadedById String   @map("uploaded_by_id")
  originalName String   @map("original_name")
  storedName   String   @map("stored_name")
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  createdAt    DateTime @default(now()) @map("created_at")

  ticket     Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation(fields: [uploadedById], references: [id])

  @@index([ticketId])
  @@map("ticket_attachments")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?  @map("actor_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  beforeJson String?  @map("before_json")
  afterJson  String?  @map("after_json")
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// Phase 5 — SLA

model BusinessHours {
  id        String @id @default(cuid())
  dayOfWeek Int    @map("day_of_week")
  startTime String @map("start_time")
  endTime   String @map("end_time")
  timezone  String @default("Africa/Accra")
  isActive  Boolean @default(true) @map("is_active")

  @@unique([dayOfWeek, startTime, endTime])
  @@map("business_hours")
}

model Holiday {
  id       String   @id @default(cuid())
  date     DateTime @db.Date
  name     String
  timezone String   @default("Africa/Accra")

  @@unique([date])
  @@map("holidays")
}

model SlaPolicy {
  id                   String  @id @default(cuid())
  name                 String
  ticketTypeId         String? @map("ticket_type_id")
  priorityId           String? @map("priority_id")
  firstResponseMinutes Int     @map("first_response_minutes")
  resolveMinutes       Int     @map("resolve_minutes")
  isActive             Boolean @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  instances   SlaInstance[]
  escalations SlaEscalationRule[]

  @@map("sla_policies")
}

model SlaInstance {
  id              String    @id @default(cuid())
  ticketId        String    @map("ticket_id")
  policyId        String    @map("policy_id")
  metric          String
  startedAt       DateTime  @map("started_at")
  dueAt           DateTime  @map("due_at")
  pausedAt        DateTime? @map("paused_at")
  completedAt     DateTime? @map("completed_at")
  breachedAt      DateTime? @map("breached_at")
  percentConsumed Float     @default(0) @map("percent_consumed")
  lastEscalationPercent Int? @map("last_escalation_percent")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  ticket Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  policy SlaPolicy @relation(fields: [policyId], references: [id])

  @@index([ticketId])
  @@index([dueAt])
  @@map("sla_instances")
}

model SlaEscalationRule {
  id               String @id @default(cuid())
  policyId         String @map("policy_id")
  thresholdPercent Int    @map("threshold_percent")
  notifyRoleCodes  String @map("notify_role_codes")

  policy SlaPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, thresholdPercent])
  @@map("sla_escalation_rules")
}

// Phase 6 — Assignment & notifications

model Skill {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  users UserSkill[]
  rules AssignmentRule[]

  @@map("skills")
}

model UserSkill {
  userId     String   @map("user_id")
  skillId    String   @map("skill_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([userId, skillId])
  @@index([skillId])
  @@map("user_skills")
}

model AssignmentRule {
  id                 String  @id @default(cuid())
  name               String
  categoryId         String? @map("category_id")
  ticketTypeId       String? @map("ticket_type_id")
  locationId         String? @map("location_id")
  teamId             String  @map("team_id")
  /** Optional skill required when auto-assigning an agent. */
  skillId            String? @map("skill_id")
  /** When true, also pick a least-loaded team member (optionally skill-filtered). */
  autoAssignAssignee Boolean @default(false) @map("auto_assign_assignee")
  priority           Int     @default(100)
  isActive           Boolean @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  skill Skill? @relation(fields: [skillId], references: [id])

  @@index([priority])
  @@map("assignment_rules")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  title     String
  body      String
  link      String?
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

model NotificationPreference {
  id            String  @id @default(cuid())
  userId        String  @map("user_id")
  eventType     String  @map("event_type")
  emailEnabled  Boolean @default(true) @map("email_enabled")
  inAppEnabled  Boolean @default(true) @map("in_app_enabled")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType])
  @@map("notification_preferences")
}

// Phase 8 — Knowledge & catalog

model KnowledgeArticle {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  /// Sanitized HTML (help-center rich text)
  body        String
  status      String    @default("draft")
  category    String?
  publishedAt DateTime? @map("published_at")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  createdBy   User                  @relation(fields: [createdById], references: [id])
  attachments KnowledgeAttachment[]

  @@index([status])
  @@map("knowledge_articles")
}

/// File attachments and inline media for knowledge articles
model KnowledgeAttachment {
  id           String   @id @default(cuid())
  articleId    String?  @map("article_id")
  uploadedById String   @map("uploaded_by_id")
  originalName String   @map("original_name")
  storedName   String   @map("stored_name")
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  /// attachment | inline
  kind         String   @default("attachment")
  createdAt    DateTime @default(now()) @map("created_at")

  article    KnowledgeArticle? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  uploadedBy User              @relation(fields: [uploadedById], references: [id])

  @@index([articleId])
  @@map("knowledge_attachments")
}

model ServiceCatalogItem {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  description    String
  ticketTypeCode String   @map("ticket_type_code")
  categoryCode   String?  @map("category_code")
  teamId         String?  @map("team_id")
  /// Dynamic request form fields (JSON array of CatalogFormField)
  formSchema     Json?    @map("form_schema")
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("service_catalog_items")
}

// Phase 9 — Assets

model AssetType {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  assets Asset[]

  @@map("asset_types")
}

model Asset {
  id                String    @id @default(cuid())
  assetTag          String    @unique @map("asset_tag")
  name              String?
  serialNumber      String?   @map("serial_number")
  typeId            String    @map("type_id")
  status            String    @default("in_stock")
  manufacturer      String?
  model             String?
  assignedUserId    String?   @map("assigned_user_id")
  locationId        String?   @map("location_id")
  purchaseDate      DateTime? @map("purchase_date")
  warrantyExpiresAt DateTime? @map("warranty_expires_at")
  notes             String?
  deletedAt         DateTime? @map("deleted_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  type         AssetType    @relation(fields: [typeId], references: [id])
  assignedUser User?        @relation("AssetAssignee", fields: [assignedUserId], references: [id])
  location     Location?    @relation(fields: [locationId], references: [id])
  tickets      TicketAsset[]

  @@index([status])
  @@index([typeId])
  @@index([assignedUserId])
  @@map("assets")
}

model TicketAsset {
  ticketId String @map("ticket_id")
  assetId  String @map("asset_id")

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  asset  Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([ticketId, assetId])
  @@map("ticket_assets")
}

model ApprovalPolicy {
  id           String  @id @default(cuid())
  name         String
  ticketTypeId String? @map("ticket_type_id")
  categoryId   String? @map("category_id")
  /** Optional change risk match: low | medium | high | critical */
  changeRisk   String? @map("change_risk")
  priority     Int     @default(100)
  isActive     Boolean @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  steps     ApprovalStep[]
  approvals Approval[]

  @@index([priority])
  @@map("approval_policies")
}

model ApprovalStep {
  id               String @id @default(cuid())
  policyId         String @map("policy_id")
  stepOrder        Int    @map("step_order")
  name             String
  /** Role code that must approve this step (e.g. approver, it_manager). */
  approverRoleCode String @map("approver_role_code")
  /** any = first approval completes step; all = every assignee must approve */
  mode             String @default("any")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  policy    ApprovalPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  approvals Approval[]

  @@unique([policyId, stepOrder])
  @@map("approval_steps")
}

model Approval {
  id         String    @id @default(cuid())
  ticketId   String    @map("ticket_id")
  approverId String    @map("approver_id")
  policyId   String?   @map("policy_id")
  stepId     String?   @map("step_id")
  stepOrder  Int?      @map("step_order")
  status     String    @default("pending")
  comment    String?
  decidedAt  DateTime? @map("decided_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  ticket   Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  approver User            @relation("ApprovalApprover", fields: [approverId], references: [id])
  policy   ApprovalPolicy? @relation(fields: [policyId], references: [id], onDelete: SetNull)
  step     ApprovalStep?   @relation(fields: [stepId], references: [id], onDelete: SetNull)

  @@index([approverId, status])
  @@index([ticketId])
  @@index([ticketId, stepOrder, status])
  @@map("approvals")
}

/** Outbound signed webhook endpoints (M5). */
model WebhookEndpoint {
  id         String   @id @default(cuid())
  name       String
  url        String
  secret     String
  isActive   Boolean  @default(true) @map("is_active")
  /** JSON string array of event types, e.g. ["ticket.created","ticket.assigned"] */
  eventTypes Json     @map("event_types")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  deliveries WebhookDelivery[]

  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id         String   @id @default(cuid())
  endpointId String   @map("endpoint_id")
  eventType  String   @map("event_type")
  payload    String
  statusCode Int?     @map("status_code")
  success    Boolean  @default(false)
  error      String?
  createdAt  DateTime @default(now()) @map("created_at")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, createdAt])
  @@map("webhook_deliveries")
}
