# LogIt — copy to .env and fill values. Never commit .env.

NODE_ENV=development
APP_NAME=LogIt
# Local dev:
APP_URL=http://localhost:3100
# Production (Hetzner / Cloudflare):
# APP_URL=https://logit.koaimpact.app

# Ports (host) — 3100/4100/8180 to avoid clashing with other local apps
WEB_PORT=3100
API_PORT=4100
NGINX_PORT=8180

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=logit
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=logit
# Host apps: 127.0.0.1:15432 (avoids local Windows Postgres on 5432). Inside Compose: postgres:5432
DATABASE_URL=postgresql://logit:change_me_strong_password@127.0.0.1:15432/logit?schema=public
POSTGRES_HOST_PORT=15432
# Dev RAM caps (docker compose) — raise only if needed
POSTGRES_MEM_LIMIT=256m
POSTGRES_SHARED_BUFFERS=64MB
POSTGRES_WORK_MEM=4MB
POSTGRES_MAX_CONNECTIONS=50

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=redis://127.0.0.1:6379
REDIS_MEM_LIMIT=96m
REDIS_MAXMEMORY=64mb

# Auth
SESSION_SECRET=replace_with_long_random_string_min_32_chars
# Production HTTPS: COOKIE_SECURE=true (session cookie Secure flag)
COOKIE_SECURE=false
# Behind reverse proxy (Nginx/Caddy/Render): set TRUST_PROXY=1 so req.ip uses X-Forwarded-For
TRUST_PROXY=
PASSWORD_MIN_LENGTH=12

# Microsoft Entra ID (optional SSO) — leave blank to hide "Sign in with Microsoft"
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
# Must match the app registration redirect URI
ENTRA_REDIRECT_URI=http://localhost:4100/api/v1/auth/sso/entra/callback
# When true, first SSO login creates an employee account if email is new
ENTRA_AUTO_PROVISION=false
ENTRA_DEFAULT_ROLE=employee

# Files
UPLOAD_MAX_BYTES=10485760
UPLOAD_DIR=./data/uploads
ALLOWED_UPLOAD_EXTENSIONS=pdf,png,jpg,jpeg,gif,doc,docx,xls,xlsx,txt,csv,zip

# AI assists (L2) — optional; without a key, heuristic classify/summarize/duplicates/SLA risk still work
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# SMTP / email (optional — outbound skipped when SMTP_HOST unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Aliases also accepted: SMTP_PASSWORD, SMTP_FROM
EMAIL_FROM=noreply@logit.local
EMAIL_INBOUND_SECRET=

# IMAP poller (optional — polls UNSEEN and creates/comments tickets)
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_MAILBOX=INBOX
IMAP_POLL_MINUTES=5
# Set IMAP_TLS=false only for non-TLS lab servers
IMAP_TLS=true

# SLA poller + auto-close (API process)
# SLA_POLL_ENABLED=false
SLA_POLL_SECONDS=60
# Days after Resolved with no reopen before auto-close (0 disables)
AUTO_CLOSE_RESOLVED_DAYS=3

# Monitoring → incident ingest (Bearer token for POST /integrations/monitoring/alerts)
MONITORING_INGEST_SECRET=

# Notification digests (M8) — interval poller on API process
# DIGEST_ENABLED=false
DIGEST_POLL_MINUTES=60
DIGEST_SEND_HOUR=8
# ISO weekday for weekly digests: 1=Mon … 7=Sun
DIGEST_WEEKDAY=1

# Public URLs (ticket deep links in chat / emails)
APP_PUBLIC_URL=http://localhost:3100
API_PUBLIC_URL=http://localhost:4100/api/v1
# Production:
# APP_PUBLIC_URL=https://logit.koaimpact.app
# API_PUBLIC_URL=https://logit.koaimpact.app/api/v1
# WEB_ORIGIN=https://logit.koaimpact.app
# COOKIE_SECURE=true
# TRUST_PROXY=1

# Chat integrations (Slack / Teams) — secrets only via env
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
# Bot Framework Microsoft App ID (JWT audience). Alias: MICROSOFT_APP_ID
TEAMS_APP_ID=
# MICROSOFT_APP_ID=
# Shared Bearer for simple connectors (fallback). Prefer TEAMS_APP_ID JWT in prod.
TEAMS_WEBHOOK_SECRET=
# Bot client secret for outbound Connector calls (not inbound verify)
TEAMS_APP_PASSWORD=
# true = accept Bot Framework Emulator JWTs (dev only)
TEAMS_ALLOW_EMULATOR=false
# Force Slack/Teams auth even outside production (true/false). Default: on when NODE_ENV=production
# INTEGRATIONS_REQUIRE_AUTH=true
INTEGRATION_SERVICE_USER_EMAIL=admin@logit.local

# Outbound signed webhooks (per-endpoint secrets in DB; Admin → Integrations)
# Set false to disable all outbound webhook deliveries
WEBHOOKS_ENABLED=true

# Scheduled report email exports (M9) — interval poller on API process
# REPORT_SCHEDULE_ENABLED=false
REPORT_SCHEDULE_POLL_MINUTES=15
# AUDIT_EXPORT_SCHEDULE_ENABLED=false
AUDIT_EXPORT_SCHEDULE_POLL_MINUTES=15

# Local seed accounts (dev only)
SEED_ADMIN_EMAIL=admin@logit.local
SEED_ADMIN_PASSWORD=LogIt-Admin-2026!
EXPOSE_RESET_TOKENS=true
WEB_ORIGIN=http://localhost:3100,http://127.0.0.1:3100
